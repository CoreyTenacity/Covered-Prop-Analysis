# Environment template for the public export of Covered.
#
# Every value below is a variable NAME only -- there are no real values here, and none should
# ever be committed. Copy this file to .env.local and fill in what you need. Variables not
# listed here correspond only to code that is intentionally excluded from this public export
# (the private scoring engine, Sharp-odds ingestion pipeline, job orchestrator, etc.) and won't
# do anything if set.

# ---------------------------------------------------------------------------
# Required for anything that reads or writes persisted data (Supabase / Postgres)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# Client-safe publishable/anon key. Either name works; PUBLISHABLE is preferred if both are set.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret key. Either name works; SERVICE_ROLE_KEY is preferred if both are set.
# Never expose this to the browser or commit a real value anywhere.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Optional: private Scoring Engine Worker proxy
# ---------------------------------------------------------------------------
# The scoring engine itself is not included in this export. If you run your own instance of it
# separately, point these at it. Without them, the parlay-analysis API route has nothing to
# proxy to.
SCORING_ENGINE_URL=
SCORING_ENGINE_SECRET=

# ---------------------------------------------------------------------------
# Optional: server-generated bearer secrets for admin/cron-adjacent routes
# ---------------------------------------------------------------------------
# These are secrets you generate yourself (e.g. a random UUID) -- not vendor API keys.
CRON_SECRET=
ADMIN_REFRESH_SECRET=

# ---------------------------------------------------------------------------
# Optional: live-provider adapters referenced by included provider/display code
# ---------------------------------------------------------------------------
# None of these are required for local development against your own Supabase data. They only
# matter if you're exercising the corresponding provider adapter directly. The private,
# scheduled ingestion jobs that call these on a cadence are NOT part of this export.
THE_ODDS_API_KEY=
SPORTS_GAME_ODDS_API_KEY=
SPORTS_GAME_ODDS_BASE_URL=https://api.sportsgameodds.com/api/v2
SPORTS_GAME_ODDS_ODDS_PATH=/odds
SPORTS_GAME_ODDS_TENNIS_ODDS_PATH=/odds
SPORTS_GAME_ODDS_TENNIS_SPORT_KEYS=tennis_atp_wta,tennis_atp,tennis_wta,tennis
SPORTS_GAME_ODDS_AUTH_HEADER=Authorization
SPORTS_GAME_ODDS_AUTH_SCHEME=Bearer
SHARPAPI_KEY=
SHARPAPI_REQUESTS_PER_REFRESH=12
SHARPAPI_MAX_REQUESTS_PER_MINUTE=
SHARPAPI_REQUEST_SPACING_MS=
BBS_API_KEY=
BBS_AUTH_HEADER=
BBS_AUTH_SCHEME=
HIGHLIGHTLY_MLB_API_KEY=
HIGHLIGHTLY_MLB_BASE_URL=https://baseball.highlightly.net
STATCAST_SAVANT_BASE_URL=https://baseballsavant.mlb.com
STATCAST_SAVANT_SEARCH_PATH=/statcast_search/csv
OPEN_METEO_BASE_URL=
OPEN_METEO_TIMEOUT_MS=
NBA_INJURY_REPORT_URL=
NFL_INJURY_REPORT_URL=
WNBA_INJURY_REPORT_URL=
NBA_COM_WNBA_LEAGUE_IDS=10,00
NBA_COM_WNBA_REQUIRE_PROBE=false
WNBA_DATA_PROVIDER=

# ---------------------------------------------------------------------------
# Optional: knowledge-layer tuning knobs (safe defaults exist for all of these)
# ---------------------------------------------------------------------------
KNOWLEDGE_LOW_EGRESS_MODE=
KNOWLEDGE_MLB_LIVE_LOOKAHEAD_HOURS=
KNOWLEDGE_PLAYER_LOG_BATCH_SIZE=
KNOWLEDGE_RECENT_LOOKBACK_DAYS=
KNOWLEDGE_SCHEDULE_DAYS_AHEAD=
MLB_WEATHER_EVENTS_PER_RUN=
MLB_WEATHER_LOOKAHEAD_HOURS=
MLB_WEATHER_REFRESH_TTL_MINUTES=

# ---------------------------------------------------------------------------
# Public-snapshot read behavior -- publication itself defaults to OFF and is not
# controlled by an env var (see README's "Safety" section); this only affects whether the
# read API is allowed to fall back to a live query when no snapshot has been published yet.
# ---------------------------------------------------------------------------
KNOWLEDGE_PUBLIC_SNAPSHOT_FALLBACK_ENABLED=
